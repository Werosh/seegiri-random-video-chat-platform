{
  "name": "seegiri",
  "private": true,
  "description": "Seegiri — production-grade random video chat platform (monorepo root)",
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint --prefix frontend && npm run lint --prefix backend",
    "format": "prettier --write \"frontend/**/*.{ts,tsx,js,mjs,json,css,md}\" \"backend/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"frontend/**/*.{ts,tsx,js,mjs,json,css,md}\" \"backend/**/*.ts\" \"*.{json,md}\""
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,mjs,json,css}": [
      "prettier --write"
    ],
    "backend/**/*.ts": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
