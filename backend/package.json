{
  "name": "seegiri-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Seegiri realtime API — Express + Socket.IO (Render/VPS ready)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
